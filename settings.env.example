# Copy to settings.env and edit for your environment.
# This file is sourced by the setup scripts.

# Identity
SERVER_NAME=homeserver
CLIENT_NAME=iphone

# Network
WG_INTERFACE=wg0
WG_SERVER_IP=10.8.0.1/24
WG_SERVER_TUNNEL_IP=10.8.0.1
WG_CLIENT_IP=10.8.0.2/24
WG_CLIENT_TUNNEL_IP=10.8.0.2
WG_SUBNET_CIDR=10.8.0.0/24

# Home LAN
LAN_IFACE=eth0
LAN_SUBNET_CIDR=192.168.1.0/24
LAN_DNS_SERVER=192.168.1.1
SERVER_LAN_IP=192.168.1.10

# WireGuard public endpoint
WG_LISTEN_PORT=51820
PUBLIC_ENDPOINT=example-ddns-name.example:51820

# iPhone routing mode:
#   server-only | lan | full-tunnel
ROUTING_MODE=lan

# Persistent keepalive for mobile/NATed clients
PERSISTENT_KEEPALIVE=25

# Caddy reverse proxy — wiring-harness managed TLS certificates
CADDY_CERTS_DIR=/etc/caddy/certs/wiring-harness

# Web Terminal (ttyd) — accessible only over the WireGuard VPN
# Set WEBTERM_ENABLED=true and run scripts/install_webterm.sh to enable.
# Prefer the canonical hostname in ../wiring-harness/services.local.toml under
# the pit-box-webterm entry. Leave WEBTERM_HOSTNAME blank to use that registry.
WEBTERM_ENABLED=false
WEBTERM_PORT=7681
WEBTERM_HOSTNAME=
WEBTERM_USER=user
# Base tmux session attached by WebTerm and managed by the loopback API.
# Use a neutral session name such as "main" when sharing WebTerm across tools.
WEBTERM_TMUX_SESSION=main
# Environment suffix appended to service unit names and the install path.
# Leave empty for production. Set to "-dev" (or similar) for a parallel dev
# instance so dev and prod can run side-by-side: ttyd-dev.service, /etc/pit-box-dev/.
WEBTERM_ENV_SUFFIX=
# Label shown in the homepage environment badge.
# Auto-derived from WEBTERM_ENV_SUFFIX when not set (empty suffix → "prod").
WEBTERM_ENV_LABEL=prod
# Full URL of the sibling environment's homepage for the homepage toggle.
# Leave empty if only one environment is deployed.
# Example: https://webterm-dev.homeserver.vpn
WEBTERM_SIBLING_URL=

# Cockpit — web-based server management UI (pre-installed on Fedora, optional on Ubuntu)
# Accessible only over the WireGuard VPN when enabled. Prefer the canonical
# hostname in ../wiring-harness/services.local.toml under pit-box-cockpit.
COCKPIT_ENABLED=false
COCKPIT_HOSTNAME=
# Port cockpit listens on (default 9090). Caddy reverse-proxies to this port.
COCKPIT_PORT=9090

# Remote Desktop (xrdp/RDP) — direct VPN-only desktop access from an RDP client
# Set REMOTE_DESKTOP_ENABLED=true and run scripts/install_remote_desktop.sh to enable.
# Prefer the canonical hostname in ../wiring-harness/services.local.toml under
# the pit-box-rdp entry. Leave REMOTE_DESKTOP_HOSTNAME blank to use that registry
# or connect directly to WG_SERVER_TUNNEL_IP.
REMOTE_DESKTOP_ENABLED=false
REMOTE_DESKTOP_PORT=3389
REMOTE_DESKTOP_BIND_ADDRESS=10.8.0.1
REMOTE_DESKTOP_HOSTNAME=
# Optional X11 desktop session id from /usr/share/xsessions, e.g. xfce, mate,
# plasma, gnome-classic. Leave blank to auto-detect.
REMOTE_DESKTOP_SESSION=

# Safari Remote Desktop (Apache Guacamole) — browser gateway to the xrdp backend
# Set REMOTE_DESKTOP_WEB_ENABLED=true to render a Caddy-protected browser endpoint.
# Prefer the canonical hostname in ../wiring-harness/services.local.toml under
# the pit-box-remote-desktop entry. Leave REMOTE_DESKTOP_WEB_HOSTNAME blank to use
# that registry. Prefer REMOTE_DESKTOP_WEB_PASSWORD_KEEPASS_ENTRY so the
# Guacamole login password is managed by the sibling auto-pass repo.
# REMOTE_DESKTOP_WEB_PASSWORD is an emergency local fallback only.
REMOTE_DESKTOP_WEB_ENABLED=false
REMOTE_DESKTOP_WEB_HOSTNAME=
REMOTE_DESKTOP_WEB_PORT=8090
REMOTE_DESKTOP_WEB_USER=iphone
REMOTE_DESKTOP_WEB_PASSWORD=
REMOTE_DESKTOP_WEB_PASSWORD_KEEPASS_ENTRY=
REMOTE_DESKTOP_WEB_PASSWORD_KEEPASS_PROFILE=your-profile
REMOTE_DESKTOP_WEB_AUTO_PASS_ENV_FILE=
REMOTE_DESKTOP_GUACAMOLE_IMAGE=docker.io/guacamole/guacamole:1.6.0
REMOTE_DESKTOP_GUACD_IMAGE=docker.io/guacamole/guacd:1.6.0
REMOTE_DESKTOP_GUACAMOLE_UID=1001
REMOTE_DESKTOP_GUACAMOLE_GID=1001
