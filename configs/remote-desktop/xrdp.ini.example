# xrdp globals managed by scripts/install_remote_desktop.sh.
# The install script edits /etc/xrdp/xrdp.ini in place and leaves a
# /etc/xrdp/xrdp.ini.pit-box.bak backup on first run.

[Globals]
port=tcp://10.8.0.1:3389
crypt_level=high
autorun=Xorg

[Xorg]
name=Xorg
lib=libxup.so
username=ask
password=ask
port=-1
code=20
