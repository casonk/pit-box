# Development environment settings overlay.
# Copy to settings.dev.env (gitignored) and edit for your dev instance.
#
# This file sources prod settings.env first, then overrides vars so dev and
# prod can run side-by-side on the same machine.
#
# Workflow: see docs/dev-prod-workflow.md

# shellcheck source=settings.env
# Uncomment the source line after copying to settings.dev.env:
# source "$(dirname "${BASH_SOURCE[0]}")/settings.env"

# --- Dev overrides below this line ---

# Port offset: dev lives 10 ports above prod (7681 prod → 7691 dev).
# WEBTERM_API_PORT is auto-computed as WEBTERM_PORT + 1.
WEBTERM_PORT=7691

# Dev hostname — register this in your wiring-harness/services.local.toml or
# add a manual dnsmasq override so it resolves over the VPN tunnel.
WEBTERM_HOSTNAME=webterm-dev.homeserver.vpn

# Suffix applied to ALL systemd unit names, container names, and install paths:
#   ttyd-dev.service, pit-box-api-dev.service, pit-box-guacamole-dev, /etc/pit-box-dev/
WEBTERM_ENV_SUFFIX=-dev

# Dev tmux session — isolated from prod so killing a dev window never affects
# a live prod terminal.
WEBTERM_TMUX_SESSION=pit-box-dev

# Label shown in the homepage environment badge (auto-derived from ENV_SUFFIX
# when not set, but explicit is clearer).
WEBTERM_ENV_LABEL=dev

# URL of the PROD homepage — used by the homepage toggle "switch to prod" link.
# Set this to your production webterm URL.
WEBTERM_SIBLING_URL=https://webterm.homeserver.vpn

# Cockpit dev override — uses the same cockpit process but a different hostname/Caddy route.
# COCKPIT_HOSTNAME=cockpit-dev.homeserver.vpn

# Desktop-web dev override — use a different port so dev and prod Guacamole coexist.
# REMOTE_DESKTOP_WEB_PORT=8091
# REMOTE_DESKTOP_WEB_HOSTNAME=remote-desktop-dev.homeserver.vpn
